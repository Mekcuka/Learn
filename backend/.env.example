DATABASE_URL=postgresql://learn:learn@localhost:5433/learn
SECRET_KEY=change-me-in-local-dev
SEED_ACCOUNTS_PATH=seed/training_accounts.json
# Запуск seed при старте uvicorn (по умолчанию false; для dev можно true)
SEED_ON_STARTUP=false
# Dev fallback: create_all при старте (prod — только alembic upgrade head)
DB_CREATE_ALL=false
# Временно без входа: все запросы идут от student@training.local
AUTH_ENABLED=false
# Редактор уроков без JWT (локально): /author доступен методисту из seed
AUTHORING_ENABLED=true
# CONTENT_ROOT=../frontend/public/content
